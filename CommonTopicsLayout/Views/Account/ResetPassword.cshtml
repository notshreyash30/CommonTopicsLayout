@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5" style="background: #fffaf8; border: 1px solid rgba(118, 70, 56, 0.25); padding: 40px; box-shadow: 0 4px 6px rgba(118, 70, 56, 0.1);">
            <div class="text-center mb-5">
                <span class="text-emerald text-uppercase tracking-widest small d-block mb-2">Security</span>
                <h2 class="serif h1" style="color: var(--emerald);">Reset Password</h2>
            </div>

            <form asp-action="ResetPassword" method="post">
                <input type="hidden" name="token" value="@Context.Request.Query["token"]" />
                <div class="mb-4">
                    <label class="small text-uppercase tracking-widest" style="color: var(--mid-tone-2);">New Password</label>
                    <input type="password" name="newPassword" class="form-control login-input" placeholder="Enter new password" required minlength="6" />
                </div>
                <button type="submit" class="btn w-100 py-3 fw-bold text-uppercase tracking-widest" style="background-color: var(--emerald); color: #fffaf8; border: none;">
                    Reset Password
                </button>
            </form>

            <div class="text-center mt-4">
                <a asp-action="Login" class="small text-decoration-none" style="color: var(--mid-tone-2);">Back to Login</a>
            </div>
        </div>
    </div>
</div>
