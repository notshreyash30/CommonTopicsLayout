@model CommonTopicsLayout.Models.LoginViewModel
@{
    ViewData["Title"] = "Access Journal";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<style>
    .login-container {
        max-width: 450px;
        margin: 80px auto;
        padding: 40px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(80, 200, 120, 0.1);
    }
    .login-input {
        background: transparent !important;
        border: none !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2) !important;
        border-radius: 0 !important;
        color: white !important;
        padding: 12px 0 !important;
    }
    .login-input:focus {
        border-bottom-color: var(--emerald) !important;
        box-shadow: none !important;
    }
    .btn-emerald-login {
        background-color: var(--emerald);
        color: var(--deep-green);
        border: none;
        transition: 0.4s;
    }
    .btn-emerald-login:hover {
        background-color: #ffffff;
        transform: translateY(-3px);
    }
</style>

<div class="container">
    <div class="login-container">
        <div class="text-center mb-5">
            <span class="text-emerald text-uppercase tracking-widest small d-block mb-2" style="color: var(--emerald);">Authentication</span>
            <h2 class="serif h1" style="color: var(--emerald);">Welcome Back.</h2>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-4">
                <label class="small text-uppercase tracking-widest text-white-50">Email Address</label>
                <input asp-for="Email" class="form-control login-input" placeholder="name@domain.com" />
            </div>

            <div class="mb-4">
                <label class="small text-uppercase tracking-widest text-white-50">Password</label>
                <input asp-for="Password" type="password" class="form-control login-input" placeholder="••••••••" />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" style="border-color: var(--emerald);">
                    <label class="form-check-label small text-white-50">Keep me signed in</label>
                </div>
                <a asp-action="ForgotPassword" class="small fw-bold text-decoration-none" style="color: var(--emerald);">Forgot?</a>
            </div>

            <button type="submit" class="btn btn-emerald-login w-100 py-3 fw-bold mb-4 text-uppercase tracking-widest">
                Enter the Circle
            </button>
        </form>
    </div>
</div>