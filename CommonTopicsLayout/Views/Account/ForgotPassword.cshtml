@{
    ViewData["Title"] = "Recover Access";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 login-container" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(80, 200, 120, 0.1); padding: 40px;">
            <div class="text-center mb-5">
                <span class="text-emerald text-uppercase tracking-widest small d-block mb-2" style="color: var(--emerald);">Security</span>
                <h2 class="serif h1" style="color: var(--emerald);">Recover Access</h2>
            </div>

            @if (ViewBag.Message != null)
            {
                <div class="alert border-emerald text-center small mb-4" style="background: rgba(80, 200, 120, 0.05); color: var(--emerald); border: 1px solid var(--emerald);">
                    @ViewBag.Message
                    @if (ViewBag.Link != null)
                    {
                        <br /><br />
                        <a href="@ViewBag.Link" class="btn btn-sm btn-outline-light rounded-0">Click here to Reset (Testing Only)</a>
                    }
                </div>
            }

            <form asp-action="ForgotPassword" method="post">
                <div class="mb-4">
                    <label class="small text-uppercase tracking-widest text-white-50">Email Address</label>
                    <input type="email" name="email" class="form-control login-input" placeholder="Enter your registered email" required />
                </div>
                <button type="submit" class="btn btn-emerald-login w-100 py-3 fw-bold text-uppercase tracking-widest" style="background-color: var(--emerald); color: var(--deep-green); border: none;">
                    Send Recovery Link
                </button>
            </form>
            
            <div class="text-center mt-4">
                <a asp-action="Login" class="small text-decoration-none text-white-50">Back to Login</a>
            </div>
        </div>
    </div>
</div>