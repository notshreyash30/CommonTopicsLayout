<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Emerald Insights</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-dark: #401a0f;
            --mid-tone-1: #7c5246;
            --mid-tone-2: #63382f;
            --mid-tone-3: #764638;
            --light-accent: #ffc4aa;
            --emerald: #764638;
            --deep-green: #fffaf8;
        }

        body {
            background-color: #fffaf8;
            color: #401a0f;
            margin-top: 90px;
        }

        .text-emerald {
            color: var(--emerald) !important;
        }
        .bg-emerald {
            background-color: var(--emerald) !important;
        }
        .border-emerald {
            border-color: var(--emerald) !important;
        }

        .navbar {
            background: rgba(255, 250, 248, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(64, 26, 15, 0.15);
        }

        .nav-link {
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 2px;
            color: rgba(64, 26, 15, 0.7) !important;
        }

            .nav-link:hover {
                color: var(--emerald) !important;
            }

        .btn-subscribe {
            background-color: var(--emerald);
            color: #fffaf8;
            border: 1px solid var(--emerald);
            transition: 0.3s;
        }
        .btn-subscribe:hover {
            background-color: var(--mid-tone-2);
            border-color: var(--mid-tone-2);
            color: #fffaf8;
        }
        .btn-outline-emerald {
            background: transparent;
            color: var(--emerald);
            border: 1px solid var(--emerald);
            transition: 0.3s;
        }
        .btn-outline-emerald:hover {
            background-color: var(--emerald);
            border-color: var(--emerald);
            color: #fffaf8;
        }
        .btn-outline-success {
            border-color: var(--emerald);
            color: var(--emerald);
            background: transparent;
        }
        .btn-outline-success:hover {
            background-color: var(--emerald);
            border-color: var(--emerald);
            color: #fffaf8;
        }
        .login-input {
            background: transparent !important;
            border: none !important;
            border-bottom: 1px solid rgba(64, 26, 15, 0.25) !important;
            border-radius: 0 !important;
            color: var(--primary-dark) !important;
            padding: 12px 0 !important;
        }
        .login-input:focus {
            border-bottom-color: var(--emerald) !important;
            box-shadow: none !important;
            outline: none;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light fixed-top">
            <div class="container">
                <a class="navbar-brand text-emerald fw-bold" asp-controller="Blog" asp-action="Index">Emerald Insights</a>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="Index">Home</a></li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            @* <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="Home">Feed</a></li> *@
                            <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="Archive">Archive</a></li>
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="About">About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="Contact">Contact</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link text-emerald" asp-controller="Blog" asp-action="Profile">Hi, @User.Identity.Name</a></li>
                            <li class="nav-item"><a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">Sign Out</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main class="container">@RenderBody()</main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>