@model IEnumerable<CommonTopicsLayout.Models.Article>
@{
    ViewData["Title"] = "The Archive";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <span class="text-emerald text-uppercase tracking-widest small d-block mb-2">Member Collection</span>
            <h1 class="serif display-4" style="color: var(--primary-dark);">The Archive</h1>
        </div>
        
        @* Button to go to the Create page *@
        <a asp-action="Create" class="btn btn-outline-success rounded-0 px-4 py-2">
            <i class="bi bi-pencil-square me-2"></i>Write New Insight
        </a>
    </div>

    <div class="row g-4">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5 border border-secondary border-dashed">
                <p style="color: var(--mid-tone-2);">The archive is silent. Be the first to share an insight.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="p-4 h-100 article-card">
                        <div class="d-flex justify-content-between small mb-3" style="color: var(--mid-tone-2);">
                            <span>@item.PublishedDate?.ToString("MMM dd, yyyy")</span>
                            <span class="badge border border-emerald text-emerald">@item.Category</span>
                        </div>
                        <h3 class="serif h4 mb-3" style="color: var(--primary-dark);">@item.Title</h3>
                        <p class="small mb-4" style="color: var(--mid-tone-2);">@item.Summary</p>
                        <div class="mt-auto pt-3 border-top" style="border-color: rgba(64, 26, 15, 0.2);">
                            <span class="small" style="color: var(--mid-tone-2);">By: @item.AuthorName</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .article-card {
        background: #fffaf8;
        border: 1px solid rgba(118, 70, 56, 0.25);
        transition: 0.3s ease;
        box-shadow: 0 2px 4px rgba(118, 70, 56, 0.1);
    }
    .article-card:hover {
        border-color: var(--emerald);
        background: rgba(255, 196, 170, 0.15);
        transform: translateY(-5px);
    }
    .border-dashed { border-style: dashed !important; }
</style>