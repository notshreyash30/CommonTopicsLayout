@model IEnumerable<CommonTopicsLayout.Models.Article>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <span class="text-emerald text-uppercase tracking-widest small d-block">Member Area</span>
                    <h2 class="serif display-6 text-white">Insight Feed</h2>
                </div>
                
                @* Button linked to Create Action *@
                <a asp-action="Create" class="btn btn-emerald-action">
                    <i class="bi bi-pencil-square me-2"></i>New Post
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="p-5 text-center" style="background: rgba(255,255,255,0.01); border: 1px dashed rgba(80, 200, 120, 0.2);">
                    <i class="bi bi-wind display-1 text-secondary opacity-25 mb-3"></i>
                    <p class="text-white-50">The feed is currently empty.</p>
                    <a asp-action="Create" class="text-emerald text-decoration-none">Start the conversation &rarr;</a>
                </div>
            }
            else
            {
                @foreach (var post in Model)
                {
                    <div class="dashboard-card mb-4">
                        <div class="p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge border border-emerald text-emerald">@post.Category</span>
                                <span class="text-white-50 small">@post.PublishedDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <h4 class="serif text-white mb-2">@post.Title</h4>
                            <p class="text-white-50 small">@post.Summary</p>
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-secondary">
                                <span class="small text-muted">Author: <span class="text-white">@post.AuthorName</span></span>
                                <a href="#" class="text-emerald text-decoration-none small fw-bold">Open &rarr;</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-lg-4 ps-lg-5 mt-5 mt-lg-0">
            <div class="p-4 border border-secondary" style="background: rgba(255,255,255,0.02);">
                <h6 class="text-emerald text-uppercase tracking-widest small mb-4">Session Details</h6>
                <div class="mb-3">
                    <label class="d-block text-white-50 small">Active Member</label>
                    <span class="text-white">@User.Identity.Name</span>
                </div>
                <hr class="border-secondary opacity-25" />
                <div class="d-grid gap-2">
                    <a asp-action="Articles" class="btn btn-sm btn-outline-light rounded-0">Browse Archive</a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-0">Log Out</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-emerald-action {
        background-color: var(--emerald);
        color: var(--deep-green);
        border: none;
        border-radius: 0;
        padding: 12px 25px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        transition: 0.3s;
    }

    .btn-emerald-action:hover {
        background-color: white;
        transform: translateY(-2px);
    }

    .dashboard-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-left: 4px solid var(--emerald);
        transition: 0.3s;
    }

    .dashboard-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--emerald);
    }
</style>