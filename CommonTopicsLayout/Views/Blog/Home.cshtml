@model IEnumerable<CommonTopicsLayout.Models.Article>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<div class="container mt-5">
    <div class="row g-5">
        <div class="col-lg-8">
            <header class="d-flex justify-content-between align-items-end mb-5">
                <div>
                    <span class="text-emerald text-uppercase tracking-widest small d-block mb-1" style="letter-spacing: 0.3rem;">Member Area</span>
                    <h2 class="serif display-6 mb-0" style="color: var(--primary-dark);">Insight Feed</h2>
                </div>

                <a asp-action="Create" class="btn btn-emerald-action">
                    <i class="bi bi-pencil-square me-2"></i>New Post
                </a>
            </header>

            @if (!Model.Any())
            {
                <div class="empty-state-box p-5 text-center">
                    <i class="bi bi-wind display-1 text-secondary opacity-25 mb-3"></i>
                    <p style="color: var(--mid-tone-2);">The feed is currently empty.</p>
                    <a asp-action="Create" class="text-emerald text-decoration-none fw-bold">Start the conversation &rarr;</a>
                </div>
            }
            else
            {
                <div class="feed-stack">
                    @foreach (var post in Model)
                    {
                        <div class="dashboard-card mb-4">
                            <div class="p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge border border-emerald text-emerald px-3 py-2">@post.Category</span>
                                    <span class="small font-monospace" style="color: var(--mid-tone-2);">@post.PublishedDate?.ToString("MMM dd, yyyy")</span>
                                </div>

                                @* Link Title to Details Page *@
                                <a asp-action="Details" asp-route-id="@post.Id" class="text-decoration-none">
                                    <h4 class="serif mb-2 hover-emerald transition-3" style="color: var(--primary-dark);">@post.Title</h4>
                                </a>

                                <p class="small lh-base" style="color: var(--mid-tone-2);">@post.Summary</p>

                                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-secondary opacity-75">
                                    @* Link Author Name to Profile Page *@
                                    <span class="small text-muted">
                                        By
                                        <a asp-action="Profile" asp-route-username="@post.AuthorName" class="text-decoration-none fw-bold hover-emerald" style="color: var(--primary-dark);">
                                            @post.AuthorName
                                        </a>
                                    </span>

                                    <a asp-action="Details" asp-route-id="@post.Id" class="text-emerald text-decoration-none small fw-bold">
                                        Open &rarr;
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-4 ps-lg-5">
            <aside class="sticky-top" style="top: 100px;">
                <div class="sidebar-panel p-4 mb-4">
                    <h6 class="text-emerald text-uppercase tracking-widest small mb-4 fw-bold">Active Session</h6>

                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-sm me-3">@User.Identity.Name[0]</div>
                        <div>
                            <span class="d-block small" style="color: var(--mid-tone-2);">Member</span>
                            <span class="fw-bold" style="color: var(--primary-dark);">@User.Identity.Name</span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        @* Link to the user's own profile *@
                        <a asp-action="Profile" asp-route-username="@User.Identity.Name" class="btn btn-sm rounded-0 text-uppercase tracking-wider" style="border-color: var(--mid-tone-3); color: var(--primary-dark);">My Profile</a>
                        <a asp-action="Archive" class="btn btn-sm btn-outline-emerald rounded-0 text-uppercase tracking-wider">Browse History</a>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-0 text-uppercase tracking-wider mt-2">Log Out</a>
                    </div>
                </div>

                <div class="p-3 border-start border-secondary opacity-75" style="border-color: var(--mid-tone-3) !important;">
                    <p class="small italic mb-0" style="color: var(--mid-tone-2);">"Digital archives are the fingerprints of our progress."</p>
                </div>
            </aside>
        </div>
    </div>
</div>

<style>
    .hover-emerald {
        transition: 0.3s;
    }

        .hover-emerald:hover {
            color: var(--emerald) !important;
        }

    .dashboard-card {
        background: rgba(255, 196, 170, 0.08);
        border: 1px solid rgba(118, 70, 56, 0.2);
        border-left: 4px solid var(--emerald);
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .dashboard-card:hover {
            background: rgba(255, 196, 170, 0.15);
            transform: translateX(8px);
            border-color: var(--emerald);
        }

    .sidebar-panel {
        background: rgba(255, 196, 170, 0.1);
        border: 1px solid rgba(118, 70, 56, 0.2);
    }

    .avatar-sm {
        width: 40px;
        height: 40px;
        background: var(--mid-tone-3);
        color: #fffaf8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        border-radius: 4px;
    }

    .empty-state-box {
        background: rgba(255, 196, 170, 0.15);
        border: 1px dashed rgba(118, 70, 56, 0.3);
    }

    .btn-emerald-action {
        background-color: var(--emerald);
        color: #fffaf8;
        border-radius: 0;
        padding: 12px 25px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

        .btn-emerald-action:hover {
            background-color: var(--light-accent);
            transform: translateY(-2px);
        }
</style>