@model CommonTopicsLayout.Models.Article

@{
    ViewData["Title"] = "Draft New Insight";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="mb-5 text-center">
                <span class="text-emerald text-uppercase tracking-widest small d-block mb-2" style="letter-spacing: 0.4rem;">Creation Lab</span>
                <h1 class="serif display-5 text-white">Draft New Insight</h1>
                <div class="mx-auto mt-3" style="width: 40px; height: 1px; background-color: var(--emerald);"></div>
            </div>

            <div class="form-container p-4 p-md-5">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label label-custom">Article Title</label>
                        <input asp-for="Title" class="form-control input-custom" placeholder="Give your insight a name..." required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <label asp-for="Category" class="form-label label-custom">Category</label>
                            <select asp-for="Category" class="form-select input-custom">
                                <option value="Tech">Technology</option>
                                <option value="Design">Digital Art & Design</option>
                                <option value="Personal">Personal Musings</option>
                                <option value="BCS">BCS Journey</option>
                                <option value="Archive">Historical Archive</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Summary" class="form-label label-custom">Short Summary</label>
                            <input asp-for="Summary" class="form-control input-custom" placeholder="A one-sentence hook..." />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label asp-for="Content" class="form-label label-custom">Main Content</label>
                        <textarea asp-for="Content" class="form-control input-custom" rows="12" placeholder="Begin your narrative here..." required></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Articles" class="text-white-50 text-decoration-none small hover-emerald transition">
                            <i class="bi bi-arrow-left me-2"></i>Back to Archive
                        </a>
                        <button type="submit" class="btn-emerald-publish">
                            Publish to the Circle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-container {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(80, 200, 120, 0.1);
        backdrop-filter: blur(10px);
    }

    .label-custom {
        color: var(--emerald);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 600;
    }

    .input-custom {
        background-color: rgba(0, 0, 0, 0.2) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        border-radius: 0 !important;
        padding: 12px 15px;
        transition: 0.3s ease;
    }

    .input-custom:focus {
        border-color: var(--emerald) !important;
        box-shadow: 0 0 10px rgba(80, 200, 120, 0.1) !important;
        background-color: rgba(0, 0, 0, 0.4) !important;
    }

    .btn-emerald-publish {
        background-color: var(--emerald);
        color: var(--deep-green);
        border: none;
        padding: 12px 35px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.8rem;
        transition: 0.3s;
    }

    .btn-emerald-publish:hover {
        background-color: #ffffff;
        color: var(--deep-green);
        transform: translateY(-2px);
    }

    .transition { transition: 0.3s; }
    .hover-emerald:hover { color: var(--emerald) !important; }
</style>