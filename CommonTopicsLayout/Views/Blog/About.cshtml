@{
    ViewData["Title"] = "Our Story";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<style>
    /* Typography & Hero */
    .about-hero-text {
        font-size: clamp(2.5rem, 8vw, 4rem);
        line-height: 1.1;
    }

    /* Values Section */
    .stat-box {
        border-right: 1px solid rgba(118, 70, 56, 0.25);
    }

    @@media (max-width: 768px) {
        .stat-box {
            border-right: none;
            border-bottom: 1px solid rgba(118, 70, 56, 0.25);
            padding-bottom: 2rem;
        }
    }

    /* Curator Cards */
    .team-card {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        filter: grayscale(100%);
        position: relative;
        cursor: pointer;
    }

        .team-card:hover {
            transform: translateY(-10px);
            filter: grayscale(0%);
            border-color: var(--emerald) !important;
        }

    .quote-mark {
        font-size: 5rem;
        color: var(--emerald);
        opacity: 0.3;
        line-height: 0;
        display: inline-block;
        transform: translateY(1.5rem);
    }

    .article-content p {
        color: var(--mid-tone-2);
        margin-bottom: 1.5rem;
    }

    /* Bio Text Styling */
    .curator-bio {
        font-size: 0.8rem;
        color: var(--mid-tone-2);
        margin-top: 8px;
        line-height: 1.4;
        font-weight: 300;
    }
</style>

<section class="py-5 mt-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="text-emerald text-uppercase tracking-widest small d-block mb-3">Manifesto</span>
                <h1 class="about-hero-text serif mb-4">Crafting digital <br /><span class="fst-italic text-emerald">longevity.</span></h1>
            </div>
            <div class="col-lg-5">
                <p class="lead fw-light" style="color: var(--mid-tone-2);">
                    In an era of disposable content and rapid-fire updates, Emerald Insights stands as a sanctuary for deep thought and architectural excellence.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 my-5" style="background: rgba(255, 196, 170, 0.2);">
    <div class="container py-5">
        <div class="row g-4 text-center">
            <div class="col-md-4 stat-box">
                <h2 class="serif text-emerald display-5">01.</h2>
                <h5 class="text-uppercase tracking-widest small mt-3">Minimalism</h5>
                <p class="small px-4 mt-2" style="color: var(--mid-tone-2);">Reducing complexity to reveal the core essence of digital design.</p>
            </div>
            <div class="col-md-4 stat-box">
                <h2 class="serif text-emerald display-5">02.</h2>
                <h5 class="text-uppercase tracking-widest small mt-3">Integrity</h5>
                <p class="small px-4 mt-2" style="color: var(--mid-tone-2);">Upholding the highest standards of code and editorial ethics.</p>
            </div>
            <div class="col-md-4 stat-box">
                <h2 class="serif text-emerald display-5">03.</h2>
                <h5 class="text-uppercase tracking-widest small mt-3">Curation</h5>
                <p class="small px-4 mt-2" style="color: var(--mid-tone-2);">Selecting only the most impactful insights for our circle.</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-9">
                <div class="mb-5">
                    <span class="quote-mark">“</span>
                    <h2 class="serif display-6 px-4 d-inline" style="color: var(--primary-dark);">We believe the web should be as enduring and beautiful as a printed book.</h2>
                    <span class="quote-mark">”</span>
                </div>
                <div class="article-content fw-light mx-auto" style="max-width: 700px;">
                    <p>Founded in 2024, Emerald Insights was born out of a frustration with the "noise" of modern tech journalism. We realized that while information was plentiful, true insight was becoming a luxury.</p>
                    <p>Our team consists of designers, philosophers, and engineers who work at the intersection of aesthetic beauty and functional perfection.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 mb-5">
    <div class="container">
        <h3 class="serif mb-5 text-center" style="color: var(--primary-dark);">The Curators</h3>
        <div class="row g-4">

            <div class="col-6 col-lg-3 text-center">
                <div class="team-card mb-3" style="aspect-ratio: 1/1; overflow: hidden; border: 1px solid rgba(118, 70, 56, 0.35);">
                    <img src="~/images/SHREYASH!.jpeg" alt="Shreyash Sundechamutha" class="img-fluid h-100 w-100" style="object-fit: cover;" onerror="this.onerror=null; this.src='@Url.Content("~/images/placeholder.svg")';" />
                </div>
                <h6 class="mb-0 fw-bold" style="color: var(--primary-dark);">Shreyash Sundechamutha</h6>
                <span class="small text-emerald text-uppercase tracking-tighter" style="font-size: 0.65rem;">Founder & Director</span>
                <p class="curator-bio">Focuses on strategic vision and ensuring digital longevity across all architectural designs.</p>
            </div>

            <div class="col-6 col-lg-3 text-center">
                <div class="team-card mb-3" style="aspect-ratio: 1/1; overflow: hidden; border: 1px solid rgba(118, 70, 56, 0.25);">
                    <img src="~/images/prem.jpeg" alt="Prem Gaikwad" class="img-fluid h-100 w-100" style="object-fit: cover;" onerror="this.onerror=null; this.src='@Url.Content("~/images/placeholder.svg")';" />
                </div>
                <h6 class="mb-0" style="color: var(--primary-dark);">Prem Gaikwad</h6>
                <span class="small text-uppercase tracking-tighter" style="font-size: 0.65rem; color: var(--mid-tone-2);">Editor in Chief</span>
                <p class="curator-bio">Curates deep-thought tech journalism with a focus on editorial ethics and integrity.</p>
            </div>

            <div class="col-6 col-lg-3 text-center">
                <div class="team-card mb-3" style="aspect-ratio: 1/1; overflow: hidden; border: 1px solid rgba(64, 26, 15, 0.25);">
                    <img src="~/images/WhatsApp Image 2026-03-15 at 11.25.19 AM.jpeg" alt="Pratik Khetre" class="img-fluid h-100 w-100" style="object-fit: cover;" onerror="this.onerror=null; this.src='@Url.Content("~/images/placeholder.svg")';" />
                </div>
                <h6 class="mb-0" style="color: var(--primary-dark);">Pratik Khetre</h6>
                <span class="small text-uppercase tracking-tighter" style="font-size: 0.65rem; color: var(--mid-tone-2);">Design Lead</span>
                <p class="curator-bio">Specializes in minimalist UI/UX, blending aesthetic beauty with functional perfection.</p>
            </div>

            <div class="col-6 col-lg-3 text-center">
                <div class="team-card mb-3" style="aspect-ratio: 1/1; overflow: hidden; border: 1px solid rgba(64, 26, 15, 0.25);">
                    <img src="~/images/Picsart_24-10-22_15-16-48-388 (4).jpg.jpeg" alt="Aditya Govekar" class="img-fluid h-100 w-100" style="object-fit: cover;object-position: top center;" onerror="this.onerror=null; this.src='@Url.Content("~/images/placeholder.svg")';" />
                </div>
                <h6 class="mb-0" style="color: var(--primary-dark);">Aditya Govekar</h6>
                <span class="small text-uppercase tracking-tighter" style="font-size: 0.65rem; color: var(--mid-tone-2);">Chief Architect</span>
                <p class="curator-bio">Architects high-performance, scalable systems and robust full-stack web solutions.</p>
            </div>

        </div>
    </div>
</section>