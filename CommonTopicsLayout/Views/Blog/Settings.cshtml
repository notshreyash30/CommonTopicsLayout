@model CommonTopicsLayout.Models.User
@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="mb-4">
                <a asp-action="Profile" asp-route-username="@User.Identity.Name" class="text-emerald text-decoration-none small fw-bold uppercase">
                    <i class="bi bi-chevron-left me-1"></i> Back to Profile
                </a>
            </div>

            <header class="mb-5">
                <h1 class="serif text-white display-5">Settings</h1>
                <p class="text-muted">Manage your digital identity and bio.</p>
            </header>

            <div class="settings-card p-4 p-md-5">
                <form asp-action="SaveSettings" method="post" enctype="multipart/form-data">

                    <div class="mb-4">
                        <label class="text-emerald x-small fw-bold d-block mb-2">Display Name</label>
                        <input type="text" class="form-control input-custom" value="@User.Identity.Name" disabled />
                    </div>

                    <div class="mb-4">
                        <label class="text-emerald x-small fw-bold d-block mb-2">Bio</label>
                        <textarea name="bio" class="form-control input-custom" rows="4">@Model?.Bio</textarea>
                    </div>

                    <div class="mb-5">
                        <label class="text-emerald x-small fw-bold d-block mb-3">Profile Photo</label>
                        <div class="d-flex align-items-center p-3 border border-secondary border-dashed">
                            @if (!string.IsNullOrEmpty(Model?.ProfilePicturePath))
                            {
                                <img src="@Model.ProfilePicturePath" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                            }
                            <input type="file" name="profilePhoto" class="form-control form-control-sm bg-transparent border-0 text-white-50 shadow-none" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-emerald-action w-100 py-3">Update Profile</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .settings-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .input-custom {
        background: rgba(0,0,0,0.3) !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        color: white !important;
        border-radius: 0;
    }

    .uppercase {
        text-transform: uppercase;
        letter-spacing: 1px;
    }
</style>