@model CommonTopicsLayout.Models.Article
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

<style>
    /* Makes the text area narrow so it is easy on the eyes */
    .reading-room {
        max-width: 800px;
        margin: 0 auto;
    }

    .serif {
        font-family: 'Playfair Display', serif;
    }

    /* The main text of your post */
    .post-content {
        font-size: 1.2rem;
        line-height: 1.9;
        color: rgba(255, 255, 255, 0.85);
        /* This keeps the "Enters" and "Paragraphs" you typed in the Create form */
        white-space: pre-line;
    }

    .meta-divider {
        width: 50px;
        height: 2px;
        background-color: #50c878;
        margin: 2rem 0;
    }

    .back-btn {
        color: #50c878;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: 0.3s;
    }

        .back-btn:hover {
            color: white;
            padding-left: 5px;
        }
</style>

<div class="container py-5 mt-5">
    <div class="reading-room">

        <nav class="mb-5">
            <a asp-action="Archive" class="back-btn">
                <i class="bi bi-arrow-left me-2"></i>Back to History
            </a>
        </nav>

        <header class="mb-5">
            <span class="text-emerald text-uppercase tracking-widest small d-block mb-3" style="letter-spacing: 2px;">
                @Model.Category
            </span>
            <h1 class="display-3 serif text-white mb-4">@Model.Title</h1>

            <div class="d-flex align-items-center mb-2">
                <div class="bg-emerald text-dark fw-bold rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                    @Model.AuthorName[0]
                </div>
                <div>
                    <p class="mb-0 text-white fw-bold">@Model.AuthorName</p>
                    <p class="mb-0 text-white-50 small">@Model.PublishedDate.ToString("MMMM dd, yyyy")</p>
                </div>
            </div>

            <div class="meta-divider"></div>
        </header>

        <article class="post-content">
            @Model.Content
        </article>

        <footer class="mt-5 pt-5 border-top border-secondary opacity-25">
            <div class="text-center">
                <p class="text-muted small italic mb-4">You have reached the end of this insight.</p>
                <a asp-action="Home" class="btn btn-outline-emerald px-5 rounded-0">Return to Feed</a>
            </div>
        </footer>

    </div>
</div>